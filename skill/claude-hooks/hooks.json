{
  "description": "Inject context-task-planning task state into Claude Code lifecycle events.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/skill/claude-hooks/scripts/session_start.py\"",
            "timeout": 8,
            "statusMessage": "Loading task context"
          }
        ]
      },
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/skill/claude-hooks/scripts/compact_session_start.py\"",
            "timeout": 12,
            "statusMessage": "Syncing compact task context"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/skill/claude-hooks/scripts/user_prompt_submit.py\"",
            "timeout": 5,
            "statusMessage": "Checking planning context"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|Edit|Write|MultiEdit|Read|Glob|Grep|Task",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/skill/claude-hooks/scripts/pre_tool_use.py\"",
            "timeout": 5,
            "statusMessage": "Refreshing task snapshot"
          }
        ]
      }
    ]
  }
}
