{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://context-task-planning.dev/schemas/context-compact.schema.json",
  "title": "Derived Compact Task Context",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "task_slug",
    "generated_at",
    "artifact",
    "freshness",
    "read_policy",
    "task",
    "distilled",
    "omitted"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "task_slug": {
      "type": "string"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "artifact": {
      "type": "object",
      "required": [
        "path",
        "persisted",
        "status"
      ],
      "properties": {
        "path": {
          "type": "string"
        },
        "persisted": {
          "type": "boolean"
        },
        "status": {
          "type": "string"
        }
      }
    },
    "freshness": {
      "type": "object",
      "required": [
        "source_fingerprint",
        "tracked_paths"
      ],
      "properties": {
        "source_fingerprint": {
          "type": "string"
        },
        "tracked_paths": {
          "type": "array"
        }
      }
    },
    "read_policy": {
      "type": "object"
    },
    "task": {
      "type": "object"
    },
    "distilled": {
      "type": "object"
    },
    "omitted": {
      "type": "object"
    },
    "compression_estimate": {
      "type": "object"
    }
  }
}
