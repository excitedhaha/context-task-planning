{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://context-task-planning.dev/schemas/delegate-status.schema.json",
  "title": "Delegate Status",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "task_slug",
    "delegate_id",
    "title",
    "kind",
    "status",
    "brief_path",
    "result_path",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "task_slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "delegate_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "kind": {
      "type": "string",
      "enum": [
        "discovery",
        "spike",
        "verify",
        "review",
        "catchup",
        "other"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "running",
        "complete",
        "blocked",
        "cancelled"
      ]
    },
    "brief_path": {
      "type": "string"
    },
    "result_path": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "files_touched": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "promoted_findings": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
