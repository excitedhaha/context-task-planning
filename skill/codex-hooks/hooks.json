{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${PLUGIN_ROOT}/skill/codex-hooks/scripts/session_start.py\"",
            "timeout": 8,
            "statusMessage": "Loading task context"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${PLUGIN_ROOT}/skill/codex-hooks/scripts/user_prompt_submit.py\"",
            "timeout": 5,
            "statusMessage": "Checking planning context"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${PLUGIN_ROOT}/skill/codex-hooks/scripts/subagent_start.py\"",
            "timeout": 5,
            "statusMessage": "Loading subagent task context"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${PLUGIN_ROOT}/skill/codex-hooks/scripts/post_tool_use.py\"",
            "timeout": 5,
            "statusMessage": "Tracking planning evidence"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${PLUGIN_ROOT}/skill/codex-hooks/scripts/stop.py\"",
            "timeout": 8,
            "statusMessage": "Checking planning sync"
          }
        ]
      }
    ]
  }
}
